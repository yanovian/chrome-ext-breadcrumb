{
  "name": "breadcrumb",
  "description": "Never lose what you learn online — highlight, save, and search your knowledge locally with on-device AI.",
  "version": "3.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm assets && wxt",
    "dev:firefox": "pnpm assets && wxt -b firefox",
    "build": "pnpm assets && wxt build",
    "build:firefox": "pnpm assets && wxt build -b firefox",
    "zip": "pnpm assets && wxt zip",
    "icons": "python3 scripts/generate-icons.py",
    "locales": "node scripts/generate-locales.mjs",
    "zip:firefox": "pnpm assets && wxt zip -b firefox",
    "assets": "pnpm sync:ort && pnpm sync:model && pnpm locales",
    "sync:ort": "node scripts/sync-ort-wasm.mjs",
    "sync:model": "node scripts/sync-model.mjs",
    "postinstall": "wxt prepare && node scripts/sync-ort-wasm.mjs && node scripts/sync-model.mjs && node scripts/generate-locales.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "packageManager": "pnpm@10.33.4+sha512.1c67b3b359b2d408119ba1ed289f34b8fc3c6873412bec6fd264fbdc82489e510fcbecb9ce9d22dae7f3b76269d8441046014bdca53b9979cd7a561ad631b800",
  "devDependencies": {
    "@types/chrome": "^0.0.320",
    "typescript": "^5.9.3",
    "vitest": "^3.2.7",
    "wxt": "^0.20.27"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.2.0"
  }
}
